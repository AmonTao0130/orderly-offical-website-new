---
import Layout from "@/layouts/index.astro";
import Content from "@/components/Content";
import Navigation from "@/components/Navigation";
import HeaderBg from "@/layouts/ecosystem/HeaderBg";
import HeaderText from "@/layouts/ecosystem/HeaderText";
import Statistics from "@/layouts/ecosystem/Statistics";
import EcosystemTab from "@/layouts/ecosystem/EcosystemTab";
import Footer from "@/components/Footer";
import { cn } from "@/utils";
import CardList from "@/layouts/ecosystem/CardList";
import CardBg from "@/layouts/ecosystem/CardBg";
---

<!-- ecosystem url有冲突，这里将 url 改成 partners -->
<Layout title="orderly.network/ecosystem">
  <div
    class={cn(
      "relative",
      /** 375 */
      "pb-[35px]",
      /** 768 */
      "md:pb-[172px]",
      /** 1024 */
      "lg:pb-[86px]",
      /** 1440 */
      "xl:pb-[124px]"
    )}
  >
    <HeaderBg />
    <div class="relative">
      <Navigation client:visible />
      <Content>
        <HeaderText />
        <Statistics />
      </Content>
    </div>
  </div>
  <div class="relative">
    <!-- <CardBg /> -->
    <div>
      <Content>
        <EcosystemTab client:visible />
        <CardList client:visible />
      </Content>

      <Footer
        className={cn(
          /** 375 */
          "mt-[40px]",
          /** 768 */
          "md:mt-[60px]",
          /** 1024 */
          "lg",
          /** 1440 */
          "xl"
        )}
        client:visible
      />
    </div>
  </div>
</Layout>
