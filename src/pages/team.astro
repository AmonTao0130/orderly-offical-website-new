---
import Layout from "@/layouts/index.astro";
import Navigation from "@/components/Navigation";
import Footer from "@/components/Footer";
import { cn } from "@/utils";
import Header from "@/layouts/team/Header";
import FooterGradient from "@/layouts/team/Gradient/Footer";
import BodyGradient from "@/layouts/team/Gradient/Body";
import Main from "@/layouts/team/Main";
import Investors from "@/layouts/team/Investors";
---

<Layout
  title="orderly.network/team"
  metaDescription="We empower Web3 teams with comprehensive dApp tools and liquidity needed to rapidly deploy sophisticated omnichain trading apps. Our infrastructure provides a unified trading order book connected to every leading blockchain."
>
  <div>
    <Navigation client:visible />
    <Header />
  </div>

  <div class="relative">
    <BodyGradient />
    <div class="relative"><Main /></div>
  </div>

  <div class="relative overflow-hidden">
    <FooterGradient />
    <div class="relative">
      <Investors />

      <Footer
        className={cn(
          /** 375 */
          "mt-[118px]",
          /** 768 */
          "md:mt-[249px]",
          /** 1024 */
          "lg:mt-[132px]",
          /** 1440 */
          "xl:mt-[120px]"
        )}
        client:visible
      />
    </div>
  </div>
</Layout>
