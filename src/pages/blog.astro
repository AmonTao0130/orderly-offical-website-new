---
import Layout from "@/layouts/index.astro";
import Navigation from "@/components/Navigation";
import HeaderBg from "@/layouts/blog/HeaderBg";
import HeaderText from "@/layouts/blog/HeaderText";
import BlogTab from "@/layouts/blog/BlogTab";
import Footer from "@/components/Footer";
import { cn } from "@/utils";
import BlogList from "@/layouts/blog/BlogList";
import "../style/index.css";
import Content from "@/components/Content";
---

<!-- 
  class={cn(
  "relative",
  /** 375 */
  "",
  /** 768 */
  "md:",
  /** 1024 */
  "lg:",
  /** 1440 */
  "xl:",
  /** 1440 */
  "2xl:"
)} 
-->
<Layout>
  <div
    class={cn(
      "relative",
      /** 375 */
      "h-[360px]",
      /** 768 */
      "md:h-[400px]"
    )}
  >
    <HeaderBg />
    <div class="relative">
      <Navigation client:visible />
      <HeaderText />
    </div>
  </div>

  <Content>
    <BlogTab client:visible />
    <BlogList client:visible />
  </Content>

  <Footer
    className={cn(
      /** 375 */
      "mt-[40px]",
      /** 768 */
      "md:mt-[72px]",
      /** 1024 */
      "lg:mt-[60px]"
    )}
  />
</Layout>
