// 返回包含分页的所有帖子的路由集合
// return paginate(articles, { pageSize: 6 });

// 嵌套分页 https://docs.astro.build/zh-cn/core-concepts/routing/#%E5%B5%8C%E5%A5%97%E5%88%86%E9%A1%B5
// return categories.map((category) => {
//   const filteredArticles = articles.filter(
//     (article) =>
//       article.attributes.category.data.attributes.slug ===
//       category.attributes.slug
//   );
//   return paginate(filteredArticles, {
//     params: { category: category.attributes.slug },
//     pageSize: 6,
//   });
// });
// }
---

<Layout
  title="Orderly Network | Blog"
  metaDescription="Orderly Network is a forward-moving protocol. Catch up on the latest updates and developments from us."
>
  <div
    class={cn(
      "relative",
      /** 375 */
      "h-[360px]",
      /** 768 */
      "md:h-[400px]"
    )}
  >
    <HeaderBg />
    <div class="relative">
      <Navigation client:visible />
      <HeaderText />
    </div>
  </div>

  <Content>
    <BlogTab data={tabData} client:visible />
    <BlogList
      publicationState={publicationState}
      client:visible
    />
  </Content>

  <Footer
    className={cn(
      /** 375 */
      "mt-[40px]",
      /** 768 */
      "md:mt-[72px]",
      /** 1024 */
      "lg:mt-[60px]"
    )}
    client:visible
  />
</Layout>
