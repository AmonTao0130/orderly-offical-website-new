---

<Layout title="orderly.network/blog">
  <div
    class={cn(
      "relative",
      /** 375 */
      "h-[360px]",
      /** 768 */
      "md:h-[400px]"
    )}
  >
    <HeaderBg />
    <div class="relative">
      <Navigation client:visible />
      <HeaderText />
    </div>
  </div>

  <Content>
    <BlogTab data={tabData} client:visible />
    <BlogList data={articles} client:visible />
  </Content>

  <Footer
    className={cn(
      /** 375 */
      "mt-[40px]",
      /** 768 */
      "md:mt-[72px]",
      /** 1024 */
      "lg:mt-[60px]"
    )}
    client:visible
  />
</Layout>
