import BlogTab from "@/layouts/blog/BlogTab";
import Footer from "@/components/Footer";
import { cn } from "@/utils";
import BlogList from "@/layouts/blog/BlogList";
import Content from "@/components/Content";
import { getCategories, getArticles } from "@/strapi/services";
import { getTabData, sortByPublishedTime } from "@/utils/strapi";
import "../../style/index.css";
// import { BlogPublishedTime } from "@/utils/constant";

const categories = await getCategories();
const tabData = getTabData(categories);

const articleList = await getArticles();

const articles = sortByPublishedTime(articleList);

