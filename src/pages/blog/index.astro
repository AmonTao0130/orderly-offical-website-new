---
export const prerender = true;

import Layout from "@/layouts/index.astro";
import Navigation from "@/components/Navigation";
import BlogTab from "@/layouts/blog/BlogTab";
import Footer from "@/components/Footer";
import { cn } from "@/utils";
import BlogList from "@/layouts/blog/BlogList";
import Content from "@/components/Content";
import {
  getArticles,
  getCategories,
  getPinArticles,
  STRAPI_MAX_PAGE_SIZE,
} from "@/strapi/services";
import { categories2Tabs } from "@/utils/strapi";
import BlogBanner from "@/layouts/blog/banner";
import "../../style/index.css";
import { PublicationStateEnum } from "@/strapi/type";

// 分类数据变动很小，编译的时候获取一次即可
const categories = await getCategories();
const tabs = categories2Tabs(categories);

// 置顶的文章
const pinArticles = await getPinArticles();

// blog 列表只需要获取第 1 页即可，第二页开始从接口获取数据，避免编译的时候一次性获取太多数据
const firstPageData = await getArticles({
  pagination: { page: 1, pageSize: STRAPI_MAX_PAGE_SIZE },
  publicationState: PublicationStateEnum.LIVE,
});

const articles = firstPageData?.data || [];

const total = firstPageData?.meta?.pagination?.total || 0;
---

<Layout
  title="Orderly | Blog"
  metaDescription="Orderly is a forward-moving protocol. Catch up on the latest updates and developments from us."
>
  <Navigation client:visible />

  <BlogBanner articles={pinArticles} client:visible />

  <Content>
    <BlogTab data={tabs} client:visible />
    <BlogList articles={articles} total={total} client:visible />
  </Content>

  <Footer
    className={cn(
      /** 375 */
      "mt-[40px]",
      /** 768 */
      "md:mt-[72px]",
      /** 1024 */
      "lg:mt-[60px]"
    )}
    client:visible
  />
</Layout>
