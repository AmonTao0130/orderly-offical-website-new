---
export const prerender = true;

import Layout from "@/layouts/index.astro";
import Navigation from "@/components/Navigation";
import BlogTab from "@/layouts/blog/BlogTab";
import Footer from "@/components/Footer";
import { cn, isDev } from "@/utils";
import BlogList from "@/layouts/blog/BlogList";
import Content from "@/components/Content";
import { getArticles, getCategories } from "@/strapi/services";
import { getTabData } from "@/utils/strapi";
import BlogBanner from "@/layouts/blog/banner";

import "../../style/index.css";

const categories = await getCategories();
const tabData = getTabData(categories);

// 如果是 dev 环境，获取草稿里的文章
const publicationState = isDev(Astro.url.hostname) ? "preview" : "live";

const pinArticlesRes = await getArticles({
  pagination: {
    page: 1,
    pageSize: 20,
  },
  publicationState,
  filters: {
    pin: {
      $eq: true,
    },
  },
});

const pinArticles = pinArticlesRes?.data || [];

// 如果是 dev 环境，获取草稿里的文章
const articlesRes = await getArticles({
  pagination: {
    page: 1,
    pageSize: 6,
  },
  publicationState,
});

// const articles = await getArticles({
//   publicationState,
//   filters: {
//     publishedAt: {
//       $gt: "2024-08-26T09:53:16.764Z",
//     },
//   },
// });

// 返回包含分页的所有帖子的路由集合
// return paginate(articles, { pageSize: 6 });

// 嵌套分页 https://docs.astro.build/zh-cn/core-concepts/routing/#%E5%B5%8C%E5%A5%97%E5%88%86%E9%A1%B5
// return categories.map((category) => {
//   const filteredArticles = articles.filter(
//     (article) =>
//       article.attributes.category.data.attributes.slug ===
//       category.attributes.slug
//   );
//   return paginate(filteredArticles, {
//     params: { category: category.attributes.slug },
//     pageSize: 6,
//   });
// });
// }
---

<Layout
  title="Orderly | Blog"
  metaDescription="Orderly is a forward-moving protocol. Catch up on the latest updates and developments from us."
>
  <Navigation client:visible />

  <BlogBanner
    articles={pinArticles}
    publicationState={publicationState}
    client:visible
  />

  <Content>
    <BlogTab data={tabData} client:visible />
    <BlogList
      articles={articlesRes?.data}
      pagination={articlesRes?.meta?.pagination}
      publicationState={publicationState}
      client:visible
    />
  </Content>

  <Footer
    className={cn(
      /** 375 */
      "mt-[40px]",
      /** 768 */
      "md:mt-[72px]",
      /** 1024 */
      "lg:mt-[60px]"
    )}
    client:visible
  />
</Layout>
