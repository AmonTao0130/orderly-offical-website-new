---
export const prerender = true;

import Layout from "@/layouts/index.astro";
import Navigation from "@/components/Navigation";
import Header from "@/layouts/blog/detail/Header";
import MoreBlog from "@/layouts/blog/detail/MoreBlog";
import BlogDetail from "@/layouts/blog/detail/BlogDetail";
import Footer from "@/components/Footer";
import { cn } from "@/utils";
import { PublicationStateEnum, type Article } from "@/strapi/type";
import { getArticleCoverImage } from "@/utils/strapi";
import { getAllPageArticleDetails } from "@/strapi/services";
import "@/layouts/blog/detail/index.less";

/** 静态渲染博客文章详情页 */
export async function getStaticPaths() {
  // 获取所有已发布的文章列表, 静态渲染只能编译已经发布的文章，因为不同环境 build 的资源是一样的
  const articles = await getAllPageArticleDetails({
    publicationState: PublicationStateEnum.LIVE,
  });

  // 获取最新发布的 3 篇文章
  const latestArticles = articles.slice(0, 3);

  return articles.map((article) => {
    return {
      params: { slug: article.attributes.slug },
      props: { article, latestArticles },
    };
  });
}

type Props = {
  article: Article;
  latestArticles: Article[];
};

const { article, latestArticles } = Astro.props;
---

<Layout
  title={`Orderly | ${article.attributes.title}`}
  metaDescription={article.attributes.description}
  image={getArticleCoverImage(article)}
>
  <Navigation client:visible />
  <Header article={article} />
  <BlogDetail article={article} client:visible />

  <MoreBlog className={cn("mt-[80px]")} data={latestArticles} client:visible />

  <Footer />
</Layout>
