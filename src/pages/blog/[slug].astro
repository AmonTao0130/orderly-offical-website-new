---
export const prerender = true;

import Layout from "@/layouts/index.astro";
import Navigation from "@/components/Navigation";
import Header from "@/layouts/blog/detail/Header";
import MoreBlog from "@/layouts/blog/detail/MoreBlog";
import BlogDetail from "@/layouts/blog/detail/BlogDetail";
import Footer from "@/components/Footer";
import { cn } from "@/utils";
import type { Article } from "@/strapi/type";
import { getArticleCoverImage } from "@/utils/strapi";
import { getArticles } from "@/strapi/services";
import "@/layouts/blog/detail/index.less";

/** 静态渲染博客文章详情页 */
export async function getStaticPaths() {
  let articles: Article[] = [];
  // 静态渲染获取已发布的文章列表
  const res1 = await getArticles({
    isDetail: true,
    pagination: { page: 1, pageSize: 100 },
  });

  articles = [...articles, ...res1?.data];

  const pageCount = res1?.meta?.pagination?.pageCount || 1;

  for (let page = 2; page <= pageCount; page++) {
    const res2 = await getArticles({
      isDetail: true,
      pagination: { page, pageSize: 100 },
    });
    articles = [...articles, ...res2?.data];
  }

  return articles.map((article) => {
    return {
      params: { slug: article.attributes.slug },
      props: { article, articles: articles?.slice(0, 3) },
    };
  });
}

type Props = {
  article: Article;
  articles: Article[];
};

const { article, articles } = Astro.props;
---

<Layout
  title={`Orderly | ${article.attributes.title}`}
  metaDescription={article.attributes.description}
  image={getArticleCoverImage(article)}
>
  <Navigation client:visible />
  <Header article={article} />
  <BlogDetail article={article} client:visible />

  <MoreBlog className={cn("mt-[80px]")} data={articles} client:visible />

  <Footer />
</Layout>
