---
export const prerender = true;

import Layout from "@/layouts/index.astro";
import Navigation from "@/components/Navigation";
import Header from "@/layouts/blog/detail/Header";
import MoreBlog from "@/layouts/blog/detail/MoreBlog";
import BlogDetail from "@/layouts/blog/detail/BlogDetail";
import Footer from "@/components/Footer";
import { cn } from "@/utils";
import type { Article } from "@/strapi/type";
import {
  getArticleCoverImage,
  getArticlesSortByDisplayTime,
} from "@/utils/strapi";
import "@/layouts/blog/detail/index.less";

/** 静态渲染博客文章详情页 */
export async function getStaticPaths() {
  const articles = await getArticlesSortByDisplayTime({ isDetail: true });

  return articles.map((article) => {
    return {
      params: { slug: article.attributes.slug },
      props: { articles, article },
    };
  });
  // return [{ params: { slug: "orderly-network-partners-here-wallet" } }];
}

type Props = {
  articles: Article[];
  article: Article;
};

const { articles, article } = Astro.props;
---

<Layout
  title={`Orderly Network | ${article.attributes.title}`}
  metaDescription={article.attributes.description}
  image={getArticleCoverImage(article)}
>
  <Navigation client:visible />
  <Header article={article} />
  <BlogDetail article={article} client:visible />

  <MoreBlog
    className={cn("mt-[80px]")}
    data={articles?.slice(0, 3)}
    client:visible
  />

  <Footer />
</Layout>
