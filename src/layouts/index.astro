---
import "@/style/index.css";

interface Props {
  title: string;
  metaDescription: string;
}

const { title, metaDescription } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <!-- dev id: G-7LT3JJYV55 -->
    <!-- prod id: G-SNRR8JX208 -->
    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-7LT3JJYV55"></script>
    <script is:inline>
      // @ts-ignore
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        // @ts-ignore
        dataLayer.push(arguments);
      }
      // @ts-ignore
      gtag("js", new Date());
      // @ts-ignore
      gtag("config", "G-7LT3JJYV55");
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="preload"
      href="/fonts/ArticulatCF/ArticulatCF-Bold.otf"
      as="font"
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={metaDescription} />
    <!-- <link rel="preload" href="/index.css" as="style" /> -->

    <title>{title}</title>
    <style>
      html,
      body {
        /** 去掉移动端点击显示阴影的问题 */
        -webkit-tap-highlight-color: transparent;
        overflow-x: hidden;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
<script>
  import { navigationOpen } from "@/store";

  window.onload = () => {
    if (history?.scrollRestoration) {
      // 禁止记录滚动位置
      history.scrollRestoration = "manual";
    }
  };

  function onTouchMove(event: TouchEvent) {
    event.preventDefault();
  }

  // 侦听导航菜单弹窗是否打开
  navigationOpen.subscribe((open) => {
    if (open) {
      document.addEventListener("touchmove", onTouchMove, {
        passive: false,
      });
    } else {
      document.removeEventListener("touchmove", onTouchMove);
    }

    // 使用fixed方案，打开弹窗的时候，body的宽度会变化，导致背景虚化有问题
    // if (open) {
    //   // document.body.style.position = "fixed";
    // } else {
    //   // document.body.style.position = "relative";
    // }
  });
</script>
